local function doSteal()
    if IsStealing then return end; local animal=nearest();if not animal then return end
    local prompt=findPrompt(animal);if not prompt then return end
    buildCallbacks(prompt); local data=stealCache[prompt]
    if not data or not data.ready then return end
    local seq=getSeq(animal); data.ready=false; IsStealing=true; StealProg=0; CONFIG.ANTI_STEAL=true; local tpDone=false
    task.spawn(function()
        equipCarpet(); task.wait(0.07)
        for _,fn in ipairs(data.hold) do task.spawn(fn) end
        local st=tick()
        while tick()-st<1.6 do
            StealProg=(tick()-st)/1.6
            if StealProg>=0.80 and not tpDone then
                tpDone=true; local hrp=getHRP()
                if hrp then
                    hrp.CFrame=seq[1];task.wait(0.1); hrp.CFrame=seq[2];task.wait(0.2)
                    local d1=(hrp.Position-pos1).Magnitude; local d2=(hrp.Position-pos2).Magnitude
                    hrp.CFrame=CFrame.new(d1<d2 and pos1 or pos2)
                    if autoPotionOn then
                        task.wait(0.15); local bp=player:FindFirstChild("Backpack"); local char=player.Character
                        local hum2=char and char:FindFirstChildOfClass("Humanoid")
                        if bp and hum2 then
                            local pot=char:FindFirstChild("Giant Potion") or bp:FindFirstChild("Giant Potion")
                            if pot then hum2:EquipTool(pot);task.wait(0.1);pcall(function() pot:Activate() end) end
                        end
                    end
                end
            end; task.wait()
        end
        StealProg=1
        for _,fn in ipairs(data.trigger) do task.spawn(fn) end
        task.wait(0.2); data.ready=true; IsStealing=false; StealProg=0; CONFIG.ANTI_STEAL=false
    end)
end

