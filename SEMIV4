local RemoteKeywords={"useitem","combatservice","ragdoll"}

local function ClearRagdollAttributes(character)
    for _,v in ipairs(character:GetDescendants()) do
        if v:IsA("BoolValue") or v:IsA("StringValue") or v:IsA("IntValue") then
            local n=v.Name:lower()
            if n:find("ragdoll") or n:find("stun") or n:find("freeze")
            or n:find("knockback") or n:find("disable") or n:find("dead") then
                pcall(function() v:Destroy() end)
            end
        end
    end
    pcall(function()
        for k,_ in pairs(character:GetAttributes()) do
            local kl=k:lower()
            if kl:find("ragdoll") or kl:find("stun") or kl:find("freeze")
            or kl:find("knockback") or kl:find("disable") then
                character:SetAttribute(k,false)
            end
        end
    end)
end
local function RestoreMotors(character)
    for _,v in ipairs(character:GetDescendants()) do
        if v:IsA("Motor6D") then v.Enabled=true
        elseif v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") then v.Enabled=false end
    end
end
local function InitAntiRagdoll(character)
    local hum=character:WaitForChild("Humanoid",10)
    local hrp=character:WaitForChild("HumanoidRootPart",10)
    if not hum or not hrp then return end
    for state in pairs(BlockedStates) do hum:SetStateEnabled(state,false) end
    hum:SetStateEnabled(Enum.HumanoidStateType.Running,true)
    hum:SetStateEnabled(Enum.HumanoidStateType.Jumping,true)
    for _,v in ipairs(character:GetDescendants()) do
        if v:IsA("Motor6D") then
            v:GetPropertyChangedSignal("Enabled"):Connect(function()
                if ENABLE_ANTI_RAGDOLL and not v.Enabled then task.wait();v.Enabled=true end
            end)
        end
    end
    character.DescendantAdded:Connect(function(v)
        if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") then
            task.wait();if ENABLE_ANTI_RAGDOLL then v.Enabled=false end
        end
        if v:IsA("BoolValue") or v:IsA("StringValue") or v:IsA("IntValue") then
            local n=v.Name:lower()
            if n:find("ragdoll") or n:find("stun") or n:find("freeze") or n:find("disable") then
                pcall(function() v:Destroy() end)
            end
        end
    end)
    hum.StateChanged:Connect(function(_,new)
        if not ENABLE_ANTI_RAGDOLL then return end
        if BlockedStates[new] then
            hum:ChangeState(Enum.HumanoidStateType.Running)
            RestoreMotors(character);ClearRagdollAttributes(character);Controls:Enable()
            if ENABLE_ANTI_KNOCKBACK then
                hrp.AssemblyLinearVelocity=Vector3.new(0,hrp.AssemblyLinearVelocity.Y,0)
                hrp.AssemblyAngularVelocity=Vector3.zero
            end
        end
    end)
    RunService.Stepped:Connect(function()
        if not ENABLE_ANTI_RAGDOLL then return end
        if BlockedStates[hum:GetState()] then
            hum:ChangeState(Enum.HumanoidStateType.Running)
            RestoreMotors(character);ClearRagdollAttributes(character);Controls:Enable()
            if ENABLE_ANTI_KNOCKBACK then
                hrp.AssemblyLinearVelocity=Vector3.new(0,hrp.AssemblyLinearVelocity.Y,0)
                hrp.AssemblyAngularVelocity=Vector3.zero
            end
        end
        if hum.Health<hum.MaxHealth then hum.Health=hum.MaxHealth end
    end)
    task.spawn(function()
        while character.Parent do task.wait(0.05)
            if ENABLE_ANTI_RAGDOLL then
                Controls:Enable();ClearRagdollAttributes(character)
                if hum.WalkSpeed<1 then hum.WalkSpeed=16 end
                if hum.JumpPower<1 then hum.JumpPower=50 end
            end
        end
    end)
end
local function KillRemote(remote)
    if not getconnections or not remote:IsA("RemoteEvent") then return end
    if DisabledRemotes[remote] then return end
    local name=remote.Name:lower()
    for _,key in ipairs(RemoteKeywords) do
        if name:find(key) then
            DisabledRemotes[remote]={}
            for _,c in ipairs(getconnections(remote.OnClientEvent)) do
                if c.Disable then c:Disable();table.insert(DisabledRemotes[remote],c) end
            end; break
        end
    end
end
local function InitAntiItem()
    Controls:Enable()
    for _,obj in ipairs(ReplicatedStorage:GetDescendants()) do KillRemote(obj) end
    ReplicatedStorage.DescendantAdded:Connect(KillRemote)
end
player.CharacterAdded:Connect(function(char) task.wait(0.4);InitAntiRagdoll(char) end)
if player.Character then InitAntiRagdoll(player.Character) end
if ENABLE_ANTI_ITEM then task.delay(0.25,InitAntiItem) end

