local espConnections={}
local function createESP(plr)
    if plr==player or not plr.Character then return end
    if plr.Character:FindFirstChild("__esp_box") then return end
    local char=plr.Character
    local hrp=char:FindFirstChild("HumanoidRootPart")
    local head=char:FindFirstChild("Head")
    if not(hrp and head) then return end
    local hitbox=Instance.new("BoxHandleAdornment"); hitbox.Name="__esp_box"
    hitbox.Adornee=hrp; hitbox.Size=Vector3.new(4,6,2)
    hitbox.Color3=Color3.fromRGB(128,0,128); hitbox.Transparency=0.6
    hitbox.ZIndex=10; hitbox.AlwaysOnTop=true; hitbox.Parent=char
    local bb=Instance.new("BillboardGui"); bb.Name="__esp_lbl"
    bb.Adornee=head; bb.Size=UDim2.new(0,200,0,50)
    bb.StudsOffset=Vector3.new(0,3,0); bb.AlwaysOnTop=true; bb.Parent=char
    local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,1,0)
    lbl.BackgroundTransparency=1
    lbl.Text=plr.DisplayName~="" and plr.DisplayName or plr.Name
    lbl.TextColor3=Color3.fromRGB(255,0,255); lbl.Font=Enum.Font.Arcade
    lbl.TextScaled=true; lbl.TextStrokeTransparency=0.7
    lbl.TextStrokeColor3=Color3.fromRGB(0,0,0); lbl.Parent=bb
end
local function removeESP(plr)
    if not plr.Character then return end
    for _,n in ipairs({"__esp_box","__esp_lbl"}) do
        local o=plr.Character:FindFirstChild(n);if o then o:Destroy() end
    end
end
local function enableESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=player then
            if plr.Character then createESP(plr) end
            local c=plr.CharacterAdded:Connect(function() task.wait(0.1);if espOn then createESP(plr) end end)
            table.insert(espConnections,c)
        end
    end
    local c2=Players.PlayerAdded:Connect(function(plr)
        if plr==player then return end
        local c3=plr.CharacterAdded:Connect(function() task.wait(0.1);if espOn then createESP(plr) end end)
        table.insert(espConnections,c3)
    end); table.insert(espConnections,c2)
    local c4=player.CharacterAdded:Connect(function()
        task.wait(0.1);if espOn then for _,plr in ipairs(Players:GetPlayers()) do if plr~=player and plr.Character then createESP(plr) end end end
    end); table.insert(espConnections,c4)
end
local function disableESP()
    for _,plr in ipairs(Players:GetPlayers()) do removeESP(plr) end
    for _,c in ipairs(espConnections) do if c and c.Connected then c:Disconnect() end end
    espConnections={}
end

